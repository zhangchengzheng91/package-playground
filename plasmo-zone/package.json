{
  "name": "宜享花开发助手",
  "displayName": "宜享花开发助手",
  "version": "0.0.2",
  "description": "宜享花开发助手",
  "author": "Plasmo Corp. <foss@plasmo.com>",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "antd": "^5.29.1",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "tabs",
      "notifications"
    ],
    "host_permissions": [
      "https://*/*"
    ],
    "commands": {
      "toggle-drawer": {
        "suggested_key": {
          "default": "Alt+Shift+K",
          "mac": "Command+Shift+K"
        },
        "description": "切换工具箱显示/隐藏"
      }
    }
  }
