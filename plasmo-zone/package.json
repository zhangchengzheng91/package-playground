{
  "name": "宜享花开发助手",
  "displayName": "宜享花开发助手",
  "version": "0.0.2",
  "description": "宜享花开发助手",
  "author": "Plasmo Corp. <foss@plasmo.com>",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "antd": "^6.3.7",
    "plasmo": "0.90.5",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@types/chrome": "0.1.40",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "prettier": "3.8.3",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "lmdb",
      "msgpackr-extract",
      "sharp"
    ]
  },
  "manifest": {
    "permissions": [
      "tabs",
      "notifications"
    ],
    "host_permissions": [
      "https://*/*"
    ],
    "commands": {
      "toggle-drawer": {
        "suggested_key": {
          "default": "Alt+Shift+K",
          "mac": "Command+Shift+K"
        },
        "description": "切换工具箱显示/隐藏"
      }
    }
  }
}